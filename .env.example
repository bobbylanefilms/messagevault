# Convex (set automatically by `pnpm convex dev`)
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk (from https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================================================
# The following go in Convex Dashboard → Settings → Environment Variables
# (NOT in this file — Convex actions run on Convex Cloud, not locally)
# ============================================================
# CLERK_ISSUER_URL=https://your-clerk-domain.clerk.accounts.dev
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# VOYAGE_API_KEY=pa-xxxxx
